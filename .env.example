# Which LLM to use for extraction: anthropic | openai
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic). Fast tier does bulk extraction;
# the strong tier is only used to repair a failed/ambiguous extraction (ADR-5).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_STRONG=claude-opus-4-8

# OpenAI (used when LLM_PROVIDER=openai; also for hosted embeddings in M2).
# Model ids are placeholders — set them to whatever you have access to.
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-5-mini
OPENAI_MODEL_STRONG=gpt-5

# The cloudscraper-go server used to fetch anti-bot protected sources.
# Start it from the sibling repo: `go run ./cmd/server` (listens on :8080).
CLOUDSCRAPER_SERVER_URL=http://127.0.0.1:8080
